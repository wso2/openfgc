{
  "name": "openfgc-portal",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.6.5",
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "tsc -b && vite build",
